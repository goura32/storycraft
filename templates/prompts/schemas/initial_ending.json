{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storycraft V1 Initial Ending Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ending",
    "long_term_arcs"
  ],
  "properties": {
    "ending": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desired_effect",
        "required_outcomes",
        "forbidden_outcomes",
        "character_end_states",
        "relationship_end_states",
        "thread_requirements",
        "final_revelations",
        "private_notes"
      ],
      "properties": {
        "desired_effect": {
          "type": "string",
          "minLength": 1,
          "maxLength": 800
        },
        "required_outcomes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "forbidden_outcomes": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "character_end_states": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "patternProperties": {
            "^char-[A-Za-z0-9_-]+$": {
              "type": "string",
              "minLength": 1,
              "maxLength": 800
            }
          }
        },
        "relationship_end_states": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "patternProperties": {
            "^rel-[A-Za-z0-9_-]+$": {
              "type": "string",
              "minLength": 1,
              "maxLength": 800
            }
          }
        },
        "thread_requirements": {
          "type": "array",
          "minItems": 1,
          "maxItems": 24,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^thread-[A-Za-z0-9_-]+$"
          }
        },
        "final_revelations": {
          "type": "array",
          "maxItems": 24,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        },
        "private_notes": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 1200
        }
      }
    },
    "long_term_arcs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 48,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_type",
          "target_id",
          "start_state",
          "turning_points",
          "desired_end_state",
          "failure_modes"
        ],
        "properties": {
          "target_type": {
            "type": "string",
            "enum": [
              "character",
              "relationship",
              "thread"
            ]
          },
          "target_id": {
            "type": "string",
            "pattern": "^(char|rel|thread)-[A-Za-z0-9_-]+$"
          },
          "start_state": {
            "type": "string",
            "minLength": 1,
            "maxLength": 800
          },
          "turning_points": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          },
          "desired_end_state": {
            "type": "string",
            "minLength": 1,
            "maxLength": 800
          },
          "failure_modes": {
            "type": "array",
            "maxItems": 12,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      }
    }
  }
}
