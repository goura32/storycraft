{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storycraft V1 Chapter Plan Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chapter_purpose",
    "starting_conditions",
    "ending_changes",
    "scene_summaries",
    "required_revelations",
    "constraints"
  ],
  "properties": {
    "chapter_purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "starting_conditions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "ending_changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "scene_summaries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scene_number",
          "purpose"
        ],
        "properties": {
          "scene_number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 32
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "required_revelations": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "constraints": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    }
  }
}
