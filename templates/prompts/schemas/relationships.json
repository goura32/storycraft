{
  "type": "object",
  "required": [
    "relationships"
  ],
  "properties": {
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "character_a_id",
          "character_b_id",
          "fixed_meaning",
          "initial_state"
        ],
        "properties": {
          "character_a_id": {
            "type": "string",
            "description": "人物AのID（characters台帳のidと一致）"
          },
          "character_b_id": {
            "type": "string",
            "description": "人物BのID（characters台帳のidと一致）"
          },
          "fixed_meaning": {
            "type": "string",
            "description": "この関係の不変の意味・定義。例：政略結婚の相手、師弟、幼馴染、主従、敵対、秘密の共有者など。物語全体で変わらない関係性の核心。"
          },
          "initial_state": {
            "type": "object",
            "description": "物語開始時点の関係状態。感情・距離感・認識のズレ・直近のきっかけのみ。他者の内面・未来の変化・本文外の因果は書かない。",
            "required": ["emotion", "situation", "recent_goal"],
            "properties": {
              "emotion": {
                "type": "string",
                "description": "互いへの主観的感情・心理的距離。複雑な混在も可。"
              },
              "situation": {
                "type": "string",
                "description": "客観的な関係上の状況・立場・環境。"
              },
              "recent_goal": {
                "type": "string",
                "description": "この関係において意識している直近の目的・願望。"
              }
            }
          }
        }
      }
    }
  }
}
