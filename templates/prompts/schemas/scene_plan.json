{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storycraft V1 Scene Plan Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "purpose",
    "pov_character_id",
    "participant_ids",
    "location_id",
    "starting_conditions",
    "intended_beats",
    "intended_revelations",
    "intended_changes",
    "prohibited_disclosures"
  ],
  "properties": {
    "purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "pov_character_id": {
      "type": "string",
      "pattern": "^char-[A-Za-z0-9_-]+$"
    },
    "participant_ids": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^char-[A-Za-z0-9_-]+$"
      }
    },
    "location_id": {
      "type": "string",
      "pattern": "^loc-[A-Za-z0-9_-]+$"
    },
    "starting_conditions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "intended_beats": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "intended_revelations": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "intended_changes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "prohibited_disclosures": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    }
  }
}
