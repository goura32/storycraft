{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storycraft V1 Volume Plan Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "starting_state_summary",
    "volume_purpose",
    "central_conflict",
    "character_changes",
    "relationship_changes",
    "thread_goals",
    "revelations",
    "chapter_summaries",
    "required_end_state",
    "handoff_expectations"
  ],
  "properties": {
    "starting_state_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1600
    },
    "volume_purpose": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "central_conflict": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1600
    },
    "character_changes": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^char-[A-Za-z0-9_-]+$": {
          "type": "string",
          "minLength": 1,
          "maxLength": 800
        }
      }
    },
    "relationship_changes": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^rel-[A-Za-z0-9_-]+$": {
          "type": "string",
          "minLength": 1,
          "maxLength": 800
        }
      }
    },
    "thread_goals": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^thread-[A-Za-z0-9_-]+$": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "revelations": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    },
    "chapter_summaries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chapter_number",
          "purpose"
        ],
        "properties": {
          "chapter_number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 64
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "required_end_state": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1600
    },
    "handoff_expectations": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      }
    }
  }
}
