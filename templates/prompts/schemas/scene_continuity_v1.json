{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storycraft V1 Scene Continuity Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "operations",
    "evidence",
    "unchanged_assertions"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "operations": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_type",
          "target_id",
          "field",
          "operation",
          "old_value",
          "new_value",
          "reason",
          "evidence_indices"
        ],
        "properties": {
          "target_type": {
            "type": "string",
            "enum": [
              "character_state",
              "relationship_state",
              "thread_state",
              "timeline_state",
              "inventory_state",
              "commitment_state"
            ]
          },
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "field": {
            "type": "string",
            "minLength": 1
          },
          "operation": {
            "const": "set"
          },
          "old_value": {},
          "new_value": {},
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "evidence_indices": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "quote",
          "occurrence",
          "context_before",
          "context_after",
          "target_type",
          "target_id",
          "change_summary"
        ],
        "properties": {
          "quote": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "occurrence": {
            "type": "integer",
            "minimum": 1
          },
          "context_before": {
            "type": "string",
            "maxLength": 1200
          },
          "context_after": {
            "type": "string",
            "maxLength": 1200
          },
          "target_type": {
            "type": "string",
            "enum": [
              "character_state",
              "relationship_state",
              "thread_state",
              "timeline_state",
              "inventory_state",
              "commitment_state"
            ]
          },
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "change_summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          }
        }
      }
    },
    "unchanged_assertions": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1200
      }
    }
  }
}
