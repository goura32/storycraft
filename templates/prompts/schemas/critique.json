{
  "type": "object",
  "required": ["issues"],
  "properties": {
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "field", "description", "suggestion"],
        "properties": {
          "severity": {"type": "string", "enum": ["critical", "major", "minor"]},
          "field": {"type": "string", "description": "問題のJSONパス"},
          "description": {"type": "string", "description": "確認できる具体的な問題"},
          "suggestion": {"type": "string", "description": "直接適用できる修正指示"}
        }
      }
    }
  }
}
