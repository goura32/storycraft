{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storycraft V1 Initial Concept",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "logline",
    "premise",
    "central_question",
    "themes",
    "dramatic_engine",
    "tone",
    "reader_promise",
    "ending_direction"
  ],
  "properties": {
    "logline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "premise": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1200
    },
    "central_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "themes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      }
    },
    "dramatic_engine": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "tone": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      }
    },
    "reader_promise": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "ending_direction": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    }
  }
}
