{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storycraft V1 Initial Characters Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["characters"],
  "properties": {
    "characters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "aliases",
          "role",
          "public_profile",
          "private_profile",
          "desires",
          "fears",
          "misbeliefs",
          "strengths",
          "weaknesses",
          "long_term_arc",
          "initial_state"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "aliases": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            }
          },
          "role": {
            "type": "string",
            "enum": [
              "protagonist",
              "co_protagonist",
              "antagonist",
              "supporting",
              "minor"
            ]
          },
          "public_profile": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "private_profile": {
            "type": "string",
            "maxLength": 1200
          },
          "desires": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            }
          },
          "fears": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            }
          },
          "misbeliefs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 240
            }
          },
          "strengths": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            }
          },
          "weaknesses": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            }
          },
          "long_term_arc": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600
          },
          "initial_state": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "emotion",
              "situation",
              "recent_goal"
            ],
            "properties": {
              "emotion": {
                "type": "string",
                "minLength": 1,
                "maxLength": 300
              },
              "situation": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500
              },
              "recent_goal": {
                "type": "string",
                "minLength": 1,
                "maxLength": 300
              }
            }
          }
        }
      }
    }
  }
}
