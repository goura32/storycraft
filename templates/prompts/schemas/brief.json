{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "storycraft://schemas/brief.json",
  "title": "Storycraft Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_type",
    "title",
    "genre",
    "premise",
    "required_elements",
    "avoid",
    "ending_preference",
    "volume_count",
    "language"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "brief",
        "keywords"
      ]
    },
    "source_reference": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "genre": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "audience": {
      "type": [
        "string",
        "null"
      ]
    },
    "tone": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "premise": {
      "type": "string",
      "minLength": 1
    },
    "central_question": {
      "type": [
        "string",
        "null"
      ]
    },
    "required_elements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "avoid": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ending_preference": {
      "type": "string",
      "minLength": 1
    },
    "volume_count": {
      "type": "integer",
      "minimum": 4,
      "maximum": 10
    },
    "language": {
      "type": "string",
      "const": "ja"
    },
    "style_preferences": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "user_notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "source_type": {
            "const": "keywords"
          }
        },
        "required": [
          "source_type"
        ]
      },
      "then": {
        "required": [
          "source_reference"
        ]
      }
    }
  ]
}
