{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storycraft V1 Initial Relationships Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["relationships"],
  "properties": {
    "relationships": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "participant_ids",
          "relationship_type",
          "public_description",
          "private_truth",
          "initial_state",
          "desired_arc",
          "constraints"
        ],
        "properties": {
          "participant_ids": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^char-[A-Za-z0-9_-]+$"
            }
          },
          "relationship_type": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "public_description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 800
          },
          "private_truth": {
            "type": "string",
            "maxLength": 1200
          },
          "initial_state": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "status",
              "trust",
              "affection",
              "hostility"
            ],
            "properties": {
              "status": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
              },
              "trust": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10
              },
              "affection": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10
              },
              "hostility": {
                "type": "integer",
                "minimum": 0,
                "maximum": 10
              }
            }
          },
          "desired_arc": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600
          },
          "constraints": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          }
        }
      }
    }
  }
}
