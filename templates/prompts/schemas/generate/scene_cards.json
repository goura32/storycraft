{
  "type": "object",
  "required": ["scene_cards"],
  "properties": {
    "scene_cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_number", "viewpoint_character", "start_time", "end_time", "location_id", "entity_ids", "purpose", "opening", "required_events", "characters", "thread_actions", "reader_disclosure", "presentation_rules", "end_change"],
        "properties": {
          "scene_number": {"type": "integer"},
          "viewpoint_character": {"type": "string"},
          "start_time": {"type": "string"},
          "end_time": {"type": "string"},
          "location_id": {"type": "string"},
          "entity_ids": {"type": "array", "items": {"type": "string"}},
          "purpose": {"type": "string"},
          "opening": {"type": "string"},
          "required_events": {"type": "array", "items": {"type": "string"}},
          "characters": {"type": "array", "items": {"type": "string"}},
          "thread_actions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "action"],
              "properties": {
                "id": {"type": "string"},
                "action": {"type": "string", "enum": ["導入", "進展", "回収"]}
              }
            }
          },
          "reader_disclosure": {"type": "string"},
          "presentation_rules": {"type": "array", "items": {"type": "string"}},
          "end_change": {"type": "string"}
        }
      }
    }
  }
}